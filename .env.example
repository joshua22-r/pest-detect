# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# For production, use:
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com/api

# Google OAuth Configuration
# Get your client ID from: https://console.cloud.google.com/
# Add authorized origins: http://localhost:3000 and your production domain
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-actual-google-client-id-here

# For production, also set:
# GOOGLE_CLIENT_ID=your-actual-google-client-id-here (in backend environment)
